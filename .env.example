# =============================================================================
# MedExRAG - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# LangSmith Configuration (Milestone 1)
# -----------------------------------------------------------------------------
# Get your API key from: https://smith.langchain.com/
# 1. Sign up/login at https://smith.langchain.com/
# 2. Click profile icon → "API Keys" → Create new key
# 3. Copy the key (starts with "lsv2_pt_")

LANGCHAIN_API_KEY=lsv2_pt_your_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=medexrag
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Enable/disable LangSmith (set to false to disable tracing)
LANGSMITH_ENABLED=true

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# LOG_FORMAT: json (production) or console (development)
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Path to ChromaDB vector database
MEDICAL_KB_PATH=./data/medical_kb

# Path to PDF literature directory
LITERATURE_DIR=./data/medical_literature

# VLM Model name (Hugging Face model ID)
MODEL_NAME=Qwen/Qwen2-VL-2B-Instruct

# Number of literature sources to retrieve for RAG
RAG_K_SOURCES=5

# -----------------------------------------------------------------------------
# OpenTelemetry Configuration (Milestone 3)
# -----------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
# OTEL_SERVICE_NAME=medexrag
# OTEL_ENABLED=true

# -----------------------------------------------------------------------------
# Prometheus Configuration (Milestone 2)
# -----------------------------------------------------------------------------
# Enable/disable Prometheus metrics collection
PROMETHEUS_ENABLED=true

# Port for metrics HTTP server (exposed for Prometheus scraping)
METRICS_PORT=8000

# Prometheus UI available at: http://localhost:9090
# Metrics endpoint available at: http://localhost:8000/metrics
